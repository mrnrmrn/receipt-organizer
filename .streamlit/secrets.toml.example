# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in your actual values
# NEVER commit secrets.toml with real values to version control

[general]
# Optional: custom app title
# app_title = "Receipt organizer"

[secrets]
# Gemini API Key for future AI features (e.g., enhanced OCR/parsing)
# Get your key from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY = "your-key-here"